# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.python-version

# --- 虛擬環境 (你目錄中的 myenv) ---
myenv/
venv/
env/
.venv/

# --- 環境變數與敏感資訊 ---
.env
.flaskenv

# --- 日誌檔案 (你目錄中的 log) ---
log/
*.log

# --- 專案特定資料 (照片通常不建議進 Git，體積較大) ---
photos/
# 如果你想保留 photos 目錄但不想傳照片，可以改用以下兩行：
# photos/*
# !photos/.gitkeep

# --- 作業系統與編輯器 ---
.DS_Store
.vscode/
.idea/
*.swp
*.bak

# --- 數據庫 (若有本地 SQLite) ---
*.sqlite3
*.db